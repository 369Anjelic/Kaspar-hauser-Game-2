{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/(.*\.html)$", "dest": "/$1" },
    { "src": "/(.*\.css)$", "dest": "/$1" },
    { "src": "/(.*\.js)$", "dest": "/$1" },
    { "src": "/(.*\.json)$", "dest": "/$1" },
    { "src": "^/$", "dest": "/index.html" }
  ]
}
